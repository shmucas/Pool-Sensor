# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key - server-side only, never exposed to the browser.
# Used by the /api/readings POST route to write rows, bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret the Pi must send in the "x-device-secret" header when
# posting readings. Generate with: openssl rand -hex 32
DEVICE_INGEST_SECRET=change-me
